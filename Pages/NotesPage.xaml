<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeechBuddyAI.Pages.NotesPage"
             Title="Notes">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="Session Notes" FontSize="22" FontAttributes="Bold" />
        <Editor Placeholder="Type or dictate your note here..." HeightRequest="180" />
        <Button Text="Summarize to SOAP" />
    </VerticalStackLayout>
</ContentPage>
