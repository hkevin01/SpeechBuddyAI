<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeechBuddyAI.Pages.NotesPage"
             Title="Notes">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="Session Notes" FontSize="22" FontAttributes="Bold" />
            <Editor x:Name="RawNoteEditor" Placeholder="Type or dictate your note here..." HeightRequest="180" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Generate Summaries"
                        Clicked="OnGenerateSummariesClicked"
                        WidthRequest="180" />
                <Button Text="Save Note"
                        Clicked="OnSaveNoteClicked"
                        WidthRequest="140" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="Export format" VerticalOptions="Center" />
                <Picker x:Name="ExportFormatPicker"
                        WidthRequest="180"
                        SelectedIndex="0"
                        SelectedIndexChanged="OnExportFormatChanged">
                    <Picker.Items>
                        <x:String>Plain Text (.txt)</x:String>
                        <x:String>Markdown (.md)</x:String>
                        <x:String>CSV Summary (.csv)</x:String>
                    </Picker.Items>
                </Picker>
            </HorizontalStackLayout>

            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Export Metadata Window" FontAttributes="Bold" />
                    <Label Text="Metadata summaries use entries from this date range." FontSize="12" TextColor="#666666" />
                    <HorizontalStackLayout Spacing="10">
                        <VerticalStackLayout>
                            <Label Text="Start" FontSize="12" />
                            <DatePicker x:Name="ExportStartDatePicker"
                                        DateSelected="OnExportPreviewWindowChanged" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="End" FontSize="12" />
                            <DatePicker x:Name="ExportEndDatePicker"
                                        DateSelected="OnExportPreviewWindowChanged" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Comparison Preview" FontAttributes="Bold" />
                    <Label x:Name="ComparisonPreviewNarrativeLabel" Text="Comparison narrative: not available yet." LineBreakMode="WordWrap" />
                    <Label x:Name="ComparisonPreviewNormalizationLabel" Text="Normalization: -" />
                    <CollectionView x:Name="ComparisonPreviewBadgesCollection"
                                    SelectionMode="None"
                                    HeightRequest="52">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BorderColor="{Binding BorderColor}" BackgroundColor="{Binding BackgroundColor}" Padding="8,4" CornerRadius="10">
                                    <VerticalStackLayout Spacing="1">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="11" />
                                        <Label Text="{Binding Value}" FontSize="11" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <CollectionView x:Name="ComparisonPreviewTimelineCollection"
                                    SelectionMode="None"
                                    HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BorderColor="#E9ECEF" BackgroundColor="#FAFAFA" Padding="8,6" Margin="0,0,0,6">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding SessionDateText}" FontAttributes="Bold" />
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding AttemptsText}" FontSize="12" />
                                            <Label Text="{Binding OverallText}" FontSize="12" />
                                            <Label Text="{Binding ConfidenceText}" FontSize="12" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DeltaText}" FontSize="12" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Assignment Analytics" FontAttributes="Bold" />
                    <Label x:Name="AssignmentAnalyticsSummaryLabel" Text="No assignment snapshots yet." />

                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Target drill-down" VerticalOptions="Center" />
                        <Picker x:Name="AssignmentTargetPicker"
                                WidthRequest="180"
                                SelectedIndexChanged="OnAssignmentTargetChanged" />
                    </HorizontalStackLayout>

                    <CollectionView x:Name="AssignmentSnapshotCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnAssignmentSnapshotSelectionChanged"
                                    HeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BorderColor="#E9ECEF" BackgroundColor="#FAFAFA" Padding="8,6" Margin="0,0,0,6">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding SnapshotDateText}" FontAttributes="Bold" FontSize="12" />
                                        <Label Text="{Binding FocusTargetsText}" FontSize="12" />
                                        <Label Text="{Binding DriftSummaryText}" FontSize="11" TextColor="#555555" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Priority Component Trends (across snapshots)" FontAttributes="Bold" FontSize="12" />

                    <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Severity" FontSize="12" VerticalOptions="Center" />
                        <CollectionView Grid.Row="0" Grid.Column="1"
                                        x:Name="SeveritySparklineCollection"
                                        SelectionMode="None"
                                        HeightRequest="30">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="3" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <BoxView WidthRequest="6"
                                             HeightRequest="{Binding Height}"
                                             VerticalOptions="End"
                                             Color="{Binding ColorHex}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Grid.Row="1" Grid.Column="0" Text="Instability" FontSize="12" VerticalOptions="Center" />
                        <CollectionView Grid.Row="1" Grid.Column="1"
                                        x:Name="InstabilitySparklineCollection"
                                        SelectionMode="None"
                                        HeightRequest="30">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="3" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <BoxView WidthRequest="6"
                                             HeightRequest="{Binding Height}"
                                             VerticalOptions="End"
                                             Color="{Binding ColorHex}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Grid.Row="2" Grid.Column="0" Text="Decline" FontSize="12" VerticalOptions="Center" />
                        <CollectionView Grid.Row="2" Grid.Column="1"
                                        x:Name="DeclineSparklineCollection"
                                        SelectionMode="None"
                                        HeightRequest="30">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="3" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <BoxView WidthRequest="6"
                                             HeightRequest="{Binding Height}"
                                             VerticalOptions="End"
                                             Color="{Binding ColorHex}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Grid.Row="3" Grid.Column="0" Text="Frequency" FontSize="12" VerticalOptions="Center" />
                        <CollectionView Grid.Row="3" Grid.Column="1"
                                        x:Name="FrequencySparklineCollection"
                                        SelectionMode="None"
                                        HeightRequest="30">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="3" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <BoxView WidthRequest="6"
                                             HeightRequest="{Binding Height}"
                                             VerticalOptions="End"
                                             Color="{Binding ColorHex}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Grid.Row="4" Grid.Column="0" Text="Confidence" FontSize="12" VerticalOptions="Center" />
                        <CollectionView Grid.Row="4" Grid.Column="1"
                                        x:Name="ConfidenceSparklineCollection"
                                        SelectionMode="None"
                                        HeightRequest="30">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="3" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <BoxView WidthRequest="6"
                                             HeightRequest="{Binding Height}"
                                             VerticalOptions="End"
                                             Color="{Binding ColorHex}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>

                    <Label x:Name="SeverityTrendChartLabel" Text="Severity trend: -" FontSize="11" TextColor="#555555" />
                    <Label x:Name="InstabilityTrendChartLabel" Text="Instability trend: -" FontSize="11" TextColor="#555555" />
                    <Label x:Name="DeclineTrendChartLabel" Text="Decline trend: -" FontSize="11" TextColor="#555555" />
                    <Label x:Name="FrequencyTrendChartLabel" Text="Frequency trend: -" FontSize="11" TextColor="#555555" />
                    <Label x:Name="ConfidenceTrendChartLabel" Text="Confidence trend: -" FontSize="11" TextColor="#555555" />
                </VerticalStackLayout>
            </Frame>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Export Latest Report"
                        Clicked="OnExportLatestClicked"
                        WidthRequest="180" />
                <Button Text="Share Latest Report"
                        Clicked="OnShareLatestClicked"
                        WidthRequest="180" />
            </HorizontalStackLayout>

            <Label x:Name="NoteStatusLabel" Text="" FontAttributes="Italic" />

            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Clinician SOAP Summary" FontAttributes="Bold" />
                    <Label x:Name="SoapSummaryLabel" Text="No summary generated yet." />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Parent-Friendly Summary" FontAttributes="Bold" />
                    <Label x:Name="ParentSummaryLabel" Text="No summary generated yet." />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Note History" FontSize="18" FontAttributes="Bold" />

            <CollectionView x:Name="NotesHistoryCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnHistorySelectionChanged">
                <CollectionView.EmptyView>
                    <Label Text="No saved notes yet." />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,8" Padding="10" BorderColor="#DDDDDD">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding SessionDate, StringFormat='{0:yyyy-MM-dd HH:mm}'}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding SoapSummary}" />
                                <Label Text="{Binding ParentSummary}" TextColor="#555555" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
