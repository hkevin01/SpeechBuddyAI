<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeechBuddyAI.Pages.SettingsPage"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Clinician Confidence Settings" FontSize="22" FontAttributes="Bold" />
            <Label Text="Tune confidence band thresholds used by scoring feedback." />

            <Frame BorderColor="#DDDDDD" Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Moderate threshold" FontAttributes="Bold" />
                    <Label x:Name="ModerateValueLabel" Text="0.60" />
                    <Slider x:Name="ModerateSlider"
                            Minimum="0.20"
                            Maximum="0.90"
                            ValueChanged="OnSliderValueChanged" />

                    <Label Text="High threshold" FontAttributes="Bold" />
                    <Label x:Name="HighValueLabel" Text="0.80" />
                    <Slider x:Name="HighSlider"
                            Minimum="0.30"
                            Maximum="0.98"
                            ValueChanged="OnSliderValueChanged" />

                    <Label Text="Session comparison normalization" FontAttributes="Bold" Margin="0,6,0,0" />
                    <Label Text="Use attempt-weighted averages or balance each target within the session day before comparison." />
                    <Picker x:Name="ComparisonNormalizationPicker">
                        <Picker.Items>
                            <x:String>Attempt-weighted averages</x:String>
                            <x:String>Day-weighted averages</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="Timeline smoothing strength" FontAttributes="Bold" Margin="0,6,0,0" />
                    <Label Text="Choose how aggressively noisy session-to-session changes are smoothed in comparison views and reports." />
                    <Picker x:Name="ComparisonSmoothingPicker">
                        <Picker.Items>
                            <x:String>Conservative smoothing</x:String>
                            <x:String>Balanced smoothing</x:String>
                            <x:String>Responsive smoothing</x:String>
                        </Picker.Items>
                    </Picker>

                            <Label Text="Assignment Priority Weights" FontAttributes="Bold" Margin="0,10,0,0" />
                            <Label Text="Tune how home assignment targets are prioritized using severity, instability, decline trend, and repetition frequency." />

                            <Label Text="Severity weight" FontAttributes="Bold" />
                            <Label x:Name="AssignmentSeverityValueLabel" Text="45%" />
                            <Slider x:Name="AssignmentSeveritySlider"
                                Minimum="0.05"
                                Maximum="0.80"
                                ValueChanged="OnSliderValueChanged" />

                            <Label Text="Instability weight" FontAttributes="Bold" />
                            <Label x:Name="AssignmentInstabilityValueLabel" Text="20%" />
                            <Slider x:Name="AssignmentInstabilitySlider"
                                Minimum="0.05"
                                Maximum="0.70"
                                ValueChanged="OnSliderValueChanged" />

                            <Label Text="Decline weight" FontAttributes="Bold" />
                            <Label x:Name="AssignmentDeclineValueLabel" Text="20%" />
                            <Slider x:Name="AssignmentDeclineSlider"
                                Minimum="0.05"
                                Maximum="0.70"
                                ValueChanged="OnSliderValueChanged" />

                            <Label Text="Frequency weight" FontAttributes="Bold" />
                            <Label x:Name="AssignmentFrequencyValueLabel" Text="15%" />
                            <Slider x:Name="AssignmentFrequencySlider"
                                Minimum="0.05"
                                Maximum="0.60"
                                ValueChanged="OnSliderValueChanged" />

                            <Label Text="Low-confidence penalty strength" FontAttributes="Bold" />
                            <Label x:Name="AssignmentConfidencePenaltyValueLabel" Text="60%" />
                            <Slider x:Name="AssignmentConfidencePenaltySlider"
                                Minimum="0.00"
                                Maximum="1.00"
                                ValueChanged="OnSliderValueChanged" />

                                <Label Text="Confidence variance gate" FontAttributes="Bold" />
                                <Label x:Name="AssignmentConfidenceVarianceGateValueLabel" Text="3.0%" />
                                <Slider x:Name="AssignmentConfidenceVarianceGateSlider"
                                    Minimum="0.005"
                                    Maximum="0.120"
                                    ValueChanged="OnSliderValueChanged" />

                                <Label Text="Suppression behavior when variance exceeds gate" FontAttributes="Bold" />
                                <Picker x:Name="AssignmentSuppressionBehaviorPicker">
                                    <Picker.Items>
                                        <x:String>Hard freeze</x:String>
                                        <x:String>Partial update</x:String>
                                        <x:String>Warning only</x:String>
                                    </Picker.Items>
                                </Picker>

                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Save Clinician Settings"
                                Clicked="OnSaveClicked"
                                HorizontalOptions="Fill"
                                WidthRequest="170" />
                        <Button Text="Reset Defaults"
                                Clicked="OnResetClicked"
                                HorizontalOptions="Fill"
                                WidthRequest="170" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#DDDDDD" Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Default Share Behavior" FontAttributes="Bold" />
                    <Label Text="Choose what happens when Share Latest Report is used in Notes." />
                    <Picker x:Name="ShareBehaviorPicker" SelectedIndex="1">
                        <Picker.Items>
                            <x:String>Export only</x:String>
                            <x:String>Export and open share sheet</x:String>
                        </Picker.Items>
                    </Picker>
                    <Button Text="Save Share Behavior"
                            Clicked="OnSaveShareBehaviorClicked"
                            WidthRequest="220" />
                </VerticalStackLayout>
            </Frame>

            <Label x:Name="StatusLabel" Text="Ready." FontAttributes="Italic" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
