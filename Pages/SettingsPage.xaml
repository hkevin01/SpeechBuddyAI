<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeechBuddyAI.Pages.SettingsPage"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Clinician Confidence Settings" FontSize="22" FontAttributes="Bold" />
            <Label Text="Tune confidence band thresholds used by scoring feedback." />

            <Frame BorderColor="#DDDDDD" Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Moderate threshold" FontAttributes="Bold" />
                    <Label x:Name="ModerateValueLabel" Text="0.60" />
                    <Slider x:Name="ModerateSlider"
                            Minimum="0.20"
                            Maximum="0.90"
                            ValueChanged="OnSliderValueChanged" />

                    <Label Text="High threshold" FontAttributes="Bold" />
                    <Label x:Name="HighValueLabel" Text="0.80" />
                    <Slider x:Name="HighSlider"
                            Minimum="0.30"
                            Maximum="0.98"
                            ValueChanged="OnSliderValueChanged" />

                    <Label Text="Session comparison normalization" FontAttributes="Bold" Margin="0,6,0,0" />
                    <Label Text="Use attempt-weighted averages or balance each target within the session day before comparison." />
                    <Picker x:Name="ComparisonNormalizationPicker">
                        <Picker.Items>
                            <x:String>Attempt-weighted averages</x:String>
                            <x:String>Day-weighted averages</x:String>
                        </Picker.Items>
                    </Picker>

                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Save Clinician Settings"
                                Clicked="OnSaveClicked"
                                HorizontalOptions="Fill"
                                WidthRequest="170" />
                        <Button Text="Reset Defaults"
                                Clicked="OnResetClicked"
                                HorizontalOptions="Fill"
                                WidthRequest="170" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#DDDDDD" Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Default Share Behavior" FontAttributes="Bold" />
                    <Label Text="Choose what happens when Share Latest Report is used in Notes." />
                    <Picker x:Name="ShareBehaviorPicker" SelectedIndex="1">
                        <Picker.Items>
                            <x:String>Export only</x:String>
                            <x:String>Export and open share sheet</x:String>
                        </Picker.Items>
                    </Picker>
                    <Button Text="Save Share Behavior"
                            Clicked="OnSaveShareBehaviorClicked"
                            WidthRequest="220" />
                </VerticalStackLayout>
            </Frame>

            <Label x:Name="StatusLabel" Text="Ready." FontAttributes="Italic" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
