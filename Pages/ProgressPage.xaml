<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeechBuddyAI.Pages.ProgressPage"
             Title="Progress">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Progress Dashboard" FontSize="22" FontAttributes="Bold" />
            <Label x:Name="TrajectoryLabel" Text="Trajectory not available yet." />

            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="FilterEntry"
                       Placeholder="Filter by target sound..."
                       HorizontalOptions="FillAndExpand"
                       WidthRequest="220"
                       TextChanged="OnFilterTextChanged" />
                <Button Text="Clear" Clicked="OnFilterClearClicked" WidthRequest="70" />
            </HorizontalStackLayout>
            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Comparison Date Range" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Start" FontSize="12" />
                            <DatePicker x:Name="ProgressStartDatePicker" DateSelected="OnDateRangeChanged" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                            <Label Text="End" FontSize="12" />
                            <DatePicker x:Name="ProgressEndDatePicker" DateSelected="OnDateRangeChanged" />
                        </VerticalStackLayout>
                    </Grid>
                    <Label x:Name="DateRangeSummaryLabel" Text="Date range: -" FontSize="12" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Session Comparison" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Frame Grid.Column="0" BorderColor="#DDE7F7" BackgroundColor="#F7FAFF" Padding="8">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Current Session" FontAttributes="Bold" />
                                <Label x:Name="CurrentSessionDateLabel" Text="Date: -" />
                                <Label x:Name="CurrentSessionAttemptsLabel" Text="Attempts: -" />
                                <Label x:Name="CurrentSessionOverallLabel" Text="Overall Avg: -" />
                                <Label x:Name="CurrentSessionConfidenceLabel" Text="Confidence Avg: -" />
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" BorderColor="#EADCF8" BackgroundColor="#FCF8FF" Padding="8">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Previous Session" FontAttributes="Bold" />
                                <Label x:Name="PreviousSessionDateLabel" Text="Date: -" />
                                <Label x:Name="PreviousSessionAttemptsLabel" Text="Attempts: -" />
                                <Label x:Name="PreviousSessionOverallLabel" Text="Overall Avg: -" />
                                <Label x:Name="PreviousSessionConfidenceLabel" Text="Confidence Avg: -" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                    <HorizontalStackLayout Spacing="14">
                        <Label x:Name="OverallDeltaLabel" Text="Overall delta: -" />
                        <Label x:Name="ConfidenceDeltaLabel" Text="Confidence delta: -" />
                    </HorizontalStackLayout>
                    <Label x:Name="ConfidenceMovementSummaryLabel" Text="Band movement: -" />
                    <Label x:Name="ComparisonNarrativeLabel" Text="Comparison narrative: -" LineBreakMode="WordWrap" />
                    <Label x:Name="NormalizationModeLabel" Text="Normalization: -" />
                    <CollectionView x:Name="SummaryBadgesCollection"
                                    SelectionMode="None"
                                    HeightRequest="52">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BorderColor="{Binding BorderColor}" BackgroundColor="{Binding BackgroundColor}" Padding="8,4" CornerRadius="10">
                                    <VerticalStackLayout Spacing="1">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="11" />
                                        <Label Text="{Binding Value}" FontSize="11" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="Target Improvements" FontAttributes="Bold" Margin="0,8,0,0" />
                    <CollectionView x:Name="TargetComparisonChips"
                                    SelectionMode="None"
                                    HeightRequest="60">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BorderColor="{Binding ChipBorderColor}" BackgroundColor="{Binding ChipBackgroundColor}" Padding="8,4" CornerRadius="12">
                                    <VerticalStackLayout Spacing="1">
                                        <Label Text="{Binding TargetSound}" FontAttributes="Bold" />
                                        <Label Text="{Binding OverallDelta, StringFormat='{0:+0%;-0%;0%}'}" FontSize="12" />
                                        <Label Text="{Binding ConfidenceMovementLabel}" FontSize="10" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="Chip Legend" FontAttributes="Bold" FontSize="12" />
                    <CollectionView x:Name="ConfidenceLegendCollection"
                                    SelectionMode="None"
                                    HeightRequest="44">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BorderColor="{Binding BorderColor}" BackgroundColor="{Binding BackgroundColor}" Padding="8,3" CornerRadius="10">
                                    <Label Text="{Binding Title}" FontSize="11" />
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="Recent Session History" FontAttributes="Bold" FontSize="12" />
                    <CollectionView x:Name="SessionTimelineCollection"
                                    SelectionMode="None"
                                    HeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BorderColor="#E9ECEF" BackgroundColor="#FAFAFA" Padding="8,6" Margin="0,0,0,6">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding SessionDateText}" FontAttributes="Bold" />
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding AttemptsText}" FontSize="12" />
                                            <Label Text="{Binding OverallText}" FontSize="12" />
                                            <Label Text="{Binding ConfidenceText}" FontSize="12" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DeltaText}" FontSize="12" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#DDDDDD" Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Score Trend (Recent Attempts)" FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="14">
                        <HorizontalStackLayout Spacing="4">
                            <BoxView Color="#4C8EDA" WidthRequest="14" HeightRequest="10" />
                            <Label Text="Overall" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4">
                            <BoxView Color="#2F9E44" WidthRequest="14" HeightRequest="10" />
                            <Label Text="Confidence" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="14">
                        <Label x:Name="ModerateThresholdLabel" Text="Moderate threshold: -" />
                        <Label x:Name="HighThresholdLabel" Text="High threshold: -" />
                    </HorizontalStackLayout>
                    <CollectionView x:Name="TrendCollection" HeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="0,4">
                                    <Label Text="{Binding AttemptIndex, StringFormat='#{0}'}" VerticalTextAlignment="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                            <Grid Grid.Column="0" WidthRequest="260" HorizontalOptions="Start">
                                                <BoxView Color="#4C8EDA"
                                                        HeightRequest="10"
                                                        WidthRequest="{Binding BarWidth}"
                                                        HorizontalOptions="Start" />
                                            </Grid>
                                            <Label Grid.Column="1"
                                                   Text="{Binding ScoreLabel}"
                                                   Margin="8,0,0,0"
                                                   VerticalTextAlignment="Center" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                            <Grid Grid.Column="0" WidthRequest="260" HorizontalOptions="Start">
                                                <BoxView Color="#F8D7A0"
                                                        WidthRequest="1"
                                                        HeightRequest="10"
                                                        HorizontalOptions="Start"
                                                        TranslationX="{Binding ModerateGuideOffset}" />
                                                <BoxView Color="#F08C00"
                                                        WidthRequest="1"
                                                        HeightRequest="10"
                                                        HorizontalOptions="Start"
                                                        TranslationX="{Binding HighGuideOffset}" />
                                                <BoxView Color="#2F9E44"
                                                        HeightRequest="10"
                                                        WidthRequest="{Binding ConfidenceBarWidth}"
                                                        HorizontalOptions="Start" />
                                            </Grid>
                                            <Label Grid.Column="1"
                                                   Text="{Binding ConfidenceLabel}"
                                                   Margin="8,0,0,0"
                                                   VerticalTextAlignment="Center" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <CollectionView x:Name="ProgressCollection">
                <CollectionView.EmptyView>
                    <Label Text="No attempts saved yet. Score an attempt in Practice." />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,10" Padding="10" BorderColor="#DDDDDD">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding TargetSound, StringFormat='Target: {0}'}" FontAttributes="Bold" />
                                <Label Text="{Binding Timestamp, StringFormat='When: {0:yyyy-MM-dd HH:mm}'}" />
                                <Label Text="{Binding TrialCount, StringFormat='Trial: {0}'}" />
                                <Label Text="{Binding PhonemeScore, StringFormat='Phoneme: {0:P0}'}" />
                                <Label Text="{Binding FluencyScore, StringFormat='Fluency: {0:P0}'}" />
                                <Label Text="{Binding ConsistencyScore, StringFormat='Consistency: {0:P0}'}" />
                                <Label Text="{Binding OverallScore, StringFormat='Overall: {0:P0}'}" FontAttributes="Bold" />
                                <Label Text="{Binding ConfidenceScore, StringFormat='Confidence: {0:P0}'}" />
                                <Label Text="{Binding ConfidenceBand, StringFormat='Confidence Band: {0}'}" />
                                <Label Text="{Binding ErrorPattern, StringFormat='Pattern: {0}'}" />
                                <Label Text="{Binding ScoringProvider, StringFormat='Provider: {0}'}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
