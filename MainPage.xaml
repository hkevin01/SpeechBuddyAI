<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeechBuddyAI.MainPage"
             Title="SpeechBuddy AI">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="SpeechBuddy AI" FontSize="32" FontAttributes="Bold" />
            <Label Text="A therapist companion app for articulation, practice planning, progress tracking, and session notes." />
            <Button Text="Open Practice" Clicked="OnPracticeClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
