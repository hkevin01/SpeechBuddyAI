<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SpeechBuddyAI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:SpeechBuddyAI.Pages"
    Title="SpeechBuddy AI">

    <TabBar>
        <ShellContent Title="Home" ContentTemplate="{DataTemplate pages:HomePage}" />
        <ShellContent Title="Practice" ContentTemplate="{DataTemplate pages:PracticePage}" />
        <ShellContent Title="Progress" ContentTemplate="{DataTemplate pages:ProgressPage}" />
        <ShellContent Title="Notes" ContentTemplate="{DataTemplate pages:NotesPage}" />
        <ShellContent Title="Settings" ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>

</Shell>
